rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.teacherId == request.auth.uid;
    }

    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    match /journals/{journalId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    match /journalStudents/{journalStudentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    match /lessons/{lessonId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    match /grades/{gradeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    match /classrooms/{classroomId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.teacherId == request.auth.uid;
    }

    match /seatingArrangements/{seatingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.teacherId == request.auth.uid;
    }

    match /conflicts/{classId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    // Artifact Groups - public read, admin write
    match /artifactGroups/{groupId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }

    // Artifacts - public read, admin write
    match /artifacts/{artifactId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }

    // Modes - public read, admin write
    match /modes/{modeId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }

    // Topics - public read, admin write
    match /topics/{topicId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
